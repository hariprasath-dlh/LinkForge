NODE_ENV=development
PORT=5000

# MongoDB Atlas

MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/linkforge?retryWrites=true&w=majority&appName=<app-name>

# JWT

JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Frontend origins

CLIENT_URL=https://your-vercel-app.vercel.app
FRONTEND_URL=https://your-vercel-app.vercel.app

# Brevo SMTP

# In Brevo: SMTP & API > SMTP > Login and SMTP Key

BREVO_SMTP_LOGIN=your_brevo_smtp_login
BREVO_USER=[your_verified_sender_email@example.com](mailto:your_verified_sender_email@example.com)
BREVO_SMTP_KEY=your_brevo_smtp_key
BREVO_FROM_EMAIL=[your_verified_sender_email@example.com](mailto:your_verified_sender_email@example.com)
EMAIL_FROM_NAME=LinkForge

# Optional SMTP tuning

SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_RETRY_ATTEMPTS=3
SMTP_CONNECTION_TIMEOUT_MS=30000
SMTP_GREETING_TIMEOUT_MS=15000
SMTP_SOCKET_TIMEOUT_MS=45000
